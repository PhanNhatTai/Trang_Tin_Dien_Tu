<script src="https://code.jquery.com/jquery-4.0.0.min.js"></script>
<script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.8/dist/js/bootstrap.bundle.min.js"></script>
<script>
    (function () {
        'use strict';
        const forms = document.querySelectorAll('.needs-validation');
        Array.from(forms).forEach(form => {
            form.addEventListener('submit', event => {
                if (!form.checkValidity()) {
                    event.preventDefault();
                    event.stopPropagation();
                }
                form.classList.add('was-validated');
            }, false);
        });
    })();
    function hienThiSuaBinhLuan(id, noiDungCu) {
        const noiDungMoi = prompt("Chỉnh sửa bình luận của bạn:", noiDungCu);
        if (noiDungMoi !== null && noiDungMoi !== noiDungCu) {
            const form = document.createElement('form');
            form.method = 'POST';
            form.action = '/baiviet/binhluan/sua/' + id;
            const inputNoiDung = document.createElement('input');
            inputNoiDung.type = 'hidden';
            inputNoiDung.name = 'NoiDungMoi';
            inputNoiDung.value = noiDungMoi;
            const inputIdBV = document.createElement('input');
            inputIdBV.type = 'hidden';
            inputIdBV.name = 'idBaiViet';
            inputIdBV.value = window.location.pathname.split('/').pop();
            form.appendChild(inputNoiDung);
            form.appendChild(inputIdBV);
            document.body.appendChild(form);
            form.submit();
        }
    }
    window.addEventListener('pageshow', function (event) {
        hienThiLichSu();
    });

</script>