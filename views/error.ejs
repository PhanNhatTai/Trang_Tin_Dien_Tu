<!DOCTYPE html>
<html lang="en">

<head>
	<%- include('head') %>
</head>

<body>
	
		<!-- Menu ngang -->
		<%- include('navbar') %>
		<div class="container mt-4">
            <div class="row justify-content-center">
                <div class="col-md-9">
		<!-- Nội dung chính -->
		<div class="card mt-3">
			<div class="card-header"><%= title %></div>
			<div class="card-body">
				<% if(typeof message !== "undefined" && message) { %>
					<div class="alert alert-danger mb-0" role="alert">
						<%- message %>
					</div>
				<% } %>
			</div>
		</div>
				</div>
			</div>
			</div>
		<!-- Footer -->
		<%- include('footer') %>
	
	
	<%- include('javascript') %>
</body>

</html>