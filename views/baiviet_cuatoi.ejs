<!DOCTYPE html>
<html lang="en">

<head>
	<%- include('head') %>
</head>

<body>
	
		<!-- Menu ngang -->
		<%- include('navbar') %>
		<div class="container mt-4">
            <div class="row justify-content-center">
                <div class="col-md-9">
		<!-- Nội dung chính -->
		<div class="card mt-2">
			<div class="card-header"><%= title %></div>
			<div class="card-body">
				<div class="container py-1">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <div>
           <h4 class="mb-0 fw-bold fs-2">Danh sách bài viết của tôi</h4>
            <p class="text-muted mb-0">Quản lý các bài viết bạn đã đăng</p>

            
        </div>
        <a href="/baiviet/them" class="btn btn-primary rounded-pill px-4 shadow-sm">
            <i class="bi bi-pencil-plus"></i> Thêm bài mới
        </a>
    </div>

    <div class="card border-0 shadow-sm rounded-4">
        <div class="card-body p-0">
            <div class="table-responsive">
                <table class="table table-hover align-middle mb-0">
                    <thead class="bg-light">
                        <tr>
                            <th class="ps-4 py-3 text-muted">#</th>
                            <th class="py-3 text-muted">Chủ đề</th>
                            <th class="py-3 text-muted">Tiêu đề</th>
                            <th class="py-3 text-muted text-center">Ngày đăng</th>
                            <th class="py-3 text-muted text-center">Trạng thái</th>
                            <th class="py-3 text-muted text-center">Hành động</th>
                            
                        </tr>
                    </thead>
                    <tbody>
                        <% if (baiviet && baiviet.length > 0) { %>
                            <% baiviet.forEach((item, index) => { %>
                                <tr>
                                    <td class="ps-4 fw-bold text-secondary"><%= index + 1 %></td>
                                    <td>
                                        <span class="badge bg-secondary-subtle text-secondary px-3 py-2 rounded-3">
                                            <%= item.TenChuDeHienThi || 'Chưa phân loại' %>
                                        </span>
                                        
                                    </td>
                                    <td>
                                        <div class="fw-bold text-dark text-truncate" style="max-width: 300px;">
                                            <%= item.TieuDe %>
                                        </div>
                                    </td>
                                    <td class="text-center text-muted">
                                        <%= item.NgayHienThi %>
                                    </td>
                                    <td class="text-center">
                                        <% if(item.KiemDuyet === 1) { %>
                                            <span class="badge bg-success-subtle text-success">Đã duyệt</span>
                                        <% } else { %>
                                            <span class="badge bg-warning-subtle text-warning">Chờ duyệt</span>
                                        <% } %>
                                    </td>
                                    <td class="text-center">
                                        <div class="btn-group">
                                            <a href="/baiviet/sua/<%= item.id %>" class="btn btn-sm btn-outline-primary border-0">
                                                <i class="bi bi-pencil-square"></i>
                                            </a>
                                            <button onclick="confirmDelete('<%= item.id %>')" class="btn btn-sm btn-outline-danger border-0">
                                                <i class="bi bi-trash3"></i>
                                            </button>
                                        </div>
                                    </td>
                                </tr>
                            <% }) %>
                        <% } else { %>
                            <tr>
                                <td colspan="6" class="text-center py-5">
                                    <img src="https://cdn-icons-png.flaticon.com/512/7486/7486744.png" width="100" class="mb-3 opacity-25">
                                    <p class="text-muted">Bạn chưa có bài viết nào. Hãy bắt đầu viết bài đầu tiên!</p>
                                </td>
                            </tr>
                        <% } %>
                    </tbody>
                </table>
            </div>
        </div>
    </div>
</div>

<script>
    function confirmDelete(id) {
        if (confirm('Bạn có chắc chắn muốn xóa bài viết này không?')) {
            window.location.href = '/baiviet/xoa/' + id;
        }
    }
</script>
			</div>
		</div>
		</div>
        </div>
        </div>
		<!-- Footer -->
		<%- include('footer') %>
	
	
	<%- include('javascript') %>
</body>

</html>