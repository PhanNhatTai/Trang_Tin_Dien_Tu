<!DOCTYPE html>
<html lang="en">

<head>
	<%- include('head') %>
</head>

<body>
	
		<!-- Menu ngang -->
		<%- include('navbar') %>
		<div class="container mt-4">
            <div class="row justify-content-center">
                <div class="col-md-9">
		<!-- Nội dung chính -->
		<div class="card mt-3">
    <div class="card-header"><%= title %></div>
    <div class="card-body">
        <form action="/taikhoan/sua/<%= taikhoan.id %>" method="post" class="needs-validation" novalidate>
            <div class="mb-3">
                <label for="HoVaTen" class="form-label">Họ và tên</label>
                <input type="text" class="form-control" id="HoVaTen" name="HoVaTen" value="<%= taikhoan.HoVaTen %>" required />
            </div>
            
            <div class="mb-3">
                <label for="Email" class="form-label">Email</label>
                <input type="email" class="form-control" id="Email" name="Email" value="<%= taikhoan.Email %>" />
            </div>
            
            <div class="mb-3">
                <label class="form-label" for="HinhDaiDien">Hình ảnh</label>
                <input type="text" class="form-control" id="HinhDaiDien" name="HinhDaiDien" value="<%= taikhoan.HinhDaiDien %>" placeholder="Tập tin ảnh đại diện" />
            </div>
            
            <div class="mb-3">
                <label for="TenDangNhap" class="form-label">Tên đăng nhập</label>
                <input type="text" class="form-control" id="TenDangNhap" name="TenDangNhap" value="<%= taikhoan.TenDangNhap %>" required />
            </div>
            
           <div class="mb-3">
							<label class="form-label" for="QuyenHan">Quyền hạn</label>
							<select class="form-select" id="QuyenHan" name="QuyenHan" required>
								<option value="user" selected>Thành viên</option>
								<option value="admin">Quản trị viên</option>
							</select>
						</div>
            
            <div class="mb-3">
                <label class="form-label" for="KichHoat">Kích hoạt</label>
                <div class="form-check">
                    <input class="form-check-input" type="radio" name="KichHoat" id="KichHoat1" value="1" <%= taikhoan.KichHoat == 1 || taikhoan.KichHoat == "1" ? "checked" : "" %> required />
                    <label class="form-check-label" for="KichHoat1">Kích hoạt</label>
                </div>
                <div class="form-check">
                    <input class="form-check-input" type="radio" name="KichHoat" id="KichHoat0" value="0" <%= taikhoan.KichHoat == 0 || taikhoan.KichHoat == "0" ? "checked" : "" %> required />
                    <label class="form-check-label" for="KichHoat0">Khóa tài khoản</label>
                </div>
            </div>
            
            <div class="mb-3">
                <label for="MatKhau" class="form-label">Mật khẩu mới</label>
                <input type="password" class="form-control" id="MatKhau" name="MatKhau" />
                <span class="d-block small text-primary">Bỏ trống nếu muốn giữ nguyên mật khẩu cũ.</span>
            </div>
            
            <div class="mb-3">
                <label for="XacNhanMatKhau" class="form-label">Xác nhận mật khẩu mới</label>
                <input type="password" class="form-control" id="XacNhanMatKhau" name="XacNhanMatKhau" />
            </div>
            
            <button type="submit" class="btn btn-primary"><i class="bi bi-cloud-arrow-up"></i> Cập nhật tài khoản</button>
        </form>
    </div>
</div>
                </div>
            </div>
            </div>
		<!-- Footer -->
		<%- include('footer') %>
	
	
	<%- include('javascript') %>
</body>

</html>